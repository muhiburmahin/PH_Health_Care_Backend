// ============================================================
// PATIENT MODELS
// ============================================================

model Patient {
  id            String    @id @default(uuid(7))
  name          String    @db.VarChar(100)
  email         String    @unique @db.VarChar(150)
  profilePhoto  String?
  contactNumber String?   @db.VarChar(20)
  address       String?   @db.Text
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  userId            String             @unique
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  appointments      Appointment[]
  prescriptions     Prescription[]
  medicalReports    MedicalReport[]
  reviews           Review[]
  patientHealthData PatientHealthData?

  @@index([email])
  @@index([isDeleted])
  @@map("patients")
}

model PatientHealthData {
  id                  String     @id @default(uuid(7))
  gender              Gender
  dateOfBirth         DateTime
  bloodGroup          BloodGroup
  hasAllergies        Boolean    @default(false)
  allergyDetails      String?    @db.Text
  hasDiabetes         Boolean    @default(false)
  height              Float
  weight              Float
  smokingStatus       Boolean    @default(false)
  dietaryPreferences  String?    @db.Text
  pregnancyStatus     Boolean    @default(false)
  mentalHealthHistory String?    @db.Text
  immunizationStatus  String?    @db.Text
  hasPastSurgeries    Boolean    @default(false)
  surgeryDetails      String?    @db.Text
  recentAnxiety       Boolean    @default(false)
  recentDepression    Boolean    @default(false)
  maritalStatus       String?    @db.VarChar(50)
  emergencyContact    String?    @db.VarChar(20)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  patientId String  @unique
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@map("patient_health_data")
}

model MedicalReport {
  id          String     @id @default(uuid(7))
  reportName  String     @db.VarChar(255)
  reportLink  String     @db.Text
  reportType  ReportType @default(OTHER)
  description String?    @db.Text
  uploadedAt  DateTime   @default(now())
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  patientId String
  patient   Patient @relation(fields: [patientId], references: [id], onDelete: Cascade)

  @@index([patientId])
  @@index([reportType])
  @@map("medical_reports")
}
